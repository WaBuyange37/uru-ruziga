# =============================================================================
# Uruziga — Environment Configuration
# =============================================================================
# Copy this file to .env.local for local development
# See DATABASE_SETUP_GUIDE.md for detailed setup instructions
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE — Choose ONE configuration below
# -----------------------------------------------------------------------------

# Option 1: Local PostgreSQL (Development)
DATABASE_URL="postgresql://username:password@localhost:5432/uru-ruziga"
DIRECT_URL="postgresql://username:password@localhost:5432/uru-ruziga"

# Option 2: Supabase (Production/Staging)
# Get these from: Supabase Dashboard → Settings → Database → Connection String
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Seed Configuration
# SEED_CLEAN="true"   # Development: Clean database before seeding
# SEED_CLEAN="false"  # Production: Preserve existing data
NODE_ENV="development"


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate local values with: openssl rand -base64 48
JWT_SECRET="replace-with-a-local-random-secret"
NEXTAUTH_SECRET="replace-with-a-local-random-secret"
NEXTAUTH_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# ⚠️  You MUST fill these in — get them from your Supabase project dashboard:
#     https://supabase.com/dashboard → your project → Settings → API
#
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Browser/client-side Supabase values. These mirror the public Supabase URL and
# anon key only. Never expose SUPABASE_SERVICE_ROLE_KEY to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"


# -----------------------------------------------------------------------------
# APPLICATION URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# PYTHON / OCR SERVICES
# -----------------------------------------------------------------------------
# These default to localhost:8000 in code, but set them explicitly here.
PYTHON_OCR_SERVICE_URL="http://localhost:8000"
PYTHON_AI_SERVICE_URL="http://localhost:8000"
NEXT_PUBLIC_EVALUATION_API_URL="http://localhost:8000"


# -----------------------------------------------------------------------------
# OPENAI (optional for local dev — drawing evaluation will fail without it)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY="sk-your-openai-api-key"


# -----------------------------------------------------------------------------
# NODE ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV="development"
