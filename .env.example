# =============================================================================
# Uruziga — Local Development Environment
# =============================================================================
# This file is committed as a template. Do not put real credentials here.
# Replace placeholder values with your actual credentials before running.
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"


# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate local-only secrets with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
URUZIGA_DEMO_PASSWORD="demo123"


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# ⚠️  You MUST fill these in — get them from your Supabase project dashboard:
#     https://supabase.com/dashboard → your project → Settings → API
#
SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="replace-with-supabase-anon-key"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"

SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"


# -----------------------------------------------------------------------------
# APPLICATION URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# -----------------------------------------------------------------------------
# PYTHON / OCR SERVICES
# -----------------------------------------------------------------------------
# These default to localhost:8000 in code, but set them explicitly here.
PYTHON_OCR_SERVICE_URL="http://localhost:8000"
PYTHON_AI_SERVICE_URL="http://localhost:8000"
NEXT_PUBLIC_EVALUATION_API_URL="http://localhost:8000"


# -----------------------------------------------------------------------------
# OPENAI (optional for local dev — drawing evaluation will fail without it)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY="sk-your-openai-api-key"


# -----------------------------------------------------------------------------
# NODE ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV="development"
