# OCR backend local development environment.
# Copy this file to .env in this directory for local OCR service startup.

# Use local PostgreSQL for Python Prisma during local development.
DATABASE_URL="postgresql://postgres:<password>@localhost:5432/uru-ruziga"

# Supabase Storage remains active for user drawings and character reference images.
SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<supabase-anon-key>"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<supabase-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<server-only-service-role-key>"

# OCR runtime settings.
UMWERO_FONT_PATH="fonts/Umwero.ttf"
REDIS_URL="redis://localhost:6379"
CACHE_DEFAULT_TTL="3600"
CACHE_REFERENCE_TTL="86400"
CACHE_FEATURE_TTL="43200"
PYTHON_LOCAL_DATASET_COLLECTION="false"
