// Umwero Handwriting OCR System Database Schema
// Optimized for ML training data collection and evaluation storage

generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Drawing attempts table - stores all handwriting evaluation attempts
model DrawingAttempt {
  id String @id @default(cuid())

  // Core evaluation data
  character      String // Target character (e.g., "a", "ka", "ngo")
  characterType  String // "vowel", "consonant", "ligature"
  userDrawing    String // File path to user's drawing image
  referenceImage String // File path to reference font image
  processedImage String // File path to processed user image
  skeletonImage  String? // File path to skeleton analysis image

  // Evaluation results
  finalScore      Float // 0-100 final evaluation score
  ssimScore       Float? // SSIM similarity score (0-1)
  contourScore    Float? // Contour matching score (0-1)
  skeletonScore   Float? // Skeleton analysis score (0-1)
  confidenceScore Float? // Algorithm confidence (0-1)

  // Automatic labeling for ML
  isCorrect    Boolean // score >= 70 = correct, < 70 = incorrect
  qualityLabel String // "excellent", "good", "poor", "invalid"

  // User context
  userId     String? // Optional user identification
  sessionId  String? // Session tracking
  deviceInfo String? // Device/browser information

  // Timing and metadata
  drawingTimeMs    Int? // Time spent drawing (milliseconds)
  evaluationTimeMs Int? // Time taken for evaluation
  submittedAt      DateTime @default(now())

  // Validation flags
  isValidSubmission Boolean  @default(true)
  validationFlags   String[] // Anti-cheat flags

  // Relations
  featureVector  FeatureVector?
  feedbackRecord FeedbackRecord?

  // Indexes for ML queries
  @@index([character])
  @@index([characterType])
  @@index([isCorrect])
  @@index([qualityLabel])
  @@index([submittedAt])
  @@index([finalScore])
  @@map("drawing_attempts")
}

// Feature vectors table - stores extracted geometric and topological features
model FeatureVector {
  id               String @id @default(cuid())
  drawingAttemptId String @unique

  // Geometric features
  contourArea       Float // Area of main contour
  aspectRatio       Float // Width/height ratio
  boundingBoxWidth  Float // Bounding box width
  boundingBoxHeight Float // Bounding box height
  perimeter         Float // Contour perimeter
  solidity          Float // Area/convex hull area
  extent            Float // Area/bounding box area

  // Topological features
  strokeCount       Int // Number of detected strokes
  loopCount         Int // Number of closed loops
  endpointCount     Int // Number of stroke endpoints
  intersectionCount Int // Number of stroke intersections

  // Shape complexity
  complexityScore Float // Overall shape complexity (0-1)
  symmetryScore   Float? // Horizontal/vertical symmetry

  // Feature vector as JSON for ML frameworks
  featureVector Json // Complete feature vector for ML

  // Timestamps
  extractedAt DateTime @default(now())

  // Relations
  drawingAttempt DrawingAttempt @relation(fields: [drawingAttemptId], references: [id], onDelete: Cascade)

  @@index([complexityScore])
  @@index([strokeCount])
  @@index([loopCount])
  @@map("feature_vectors")
}

// Feedback records table - stores detailed feedback and analysis
model FeedbackRecord {
  id               String @id @default(cuid())
  drawingAttemptId String @unique

  // Overall feedback
  overallFeedback String // Main feedback message
  encouragement   String? // Positive reinforcement message

  // Specific issues detected
  missingStrokes    String[] // List of missing stroke descriptions
  proportionIssues  String[] // Proportion-related feedback
  positioningIssues String[] // Positioning-related feedback
  topologyIssues    String[] // Shape topology issues

  // Improvement suggestions
  suggestions   String[] // Specific improvement suggestions
  practiceAreas String[] // Areas to focus practice on

  // Feedback metadata
  feedbackType String // "positive", "constructive", "corrective"
  priority     String // "high", "medium", "low"

  // Timestamps
  generatedAt DateTime @default(now())

  // Relations
  drawingAttempt DrawingAttempt @relation(fields: [drawingAttemptId], references: [id], onDelete: Cascade)

  @@index([feedbackType])
  @@index([priority])
  @@map("feedback_records")
}

// Character profiles for score calibration
model CharacterProfile {
  id String @id @default(cuid())

  // Character identification
  character     String @unique // The character (e.g., "a", "ka", "ngo")
  characterType String // "vowel", "consonant", "ligature"

  // Difficulty assessment
  difficultyLevel  Float // 1.0 (easy) to 5.0 (very hard)
  strokeComplexity Float // Complexity based on stroke count/patterns
  hasLoops         Boolean // Whether character contains loops
  hasCurves        Boolean // Whether character contains curves

  // Score calibration settings
  scoreAdjustment Float @default(0.0) // Adjustment factor (-20 to +20)
  toleranceLevel  Float @default(1.0) // Tolerance multiplier (0.5 to 2.0)

  // Statistical data (updated from user submissions)
  averageScore  Float? // Average score from all attempts
  successRate   Float? // Percentage of attempts scoring >= 70
  totalAttempts Int    @default(0)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([character])
  @@index([characterType])
  @@index([difficultyLevel])
  @@map("character_profiles")
}

// System performance metrics
model PerformanceMetric {
  id String @id @default(cuid())

  // Metric identification
  metricType String // "response_time", "cache_hit_rate", "error_rate"
  component  String // "font_renderer", "image_processor", "comparison_algorithm"

  // Metric values
  value Float // The metric value
  unit  String // "ms", "percentage", "count"

  // Context
  characterType String? // Associated character type if applicable
  timestamp     DateTime @default(now())

  @@index([metricType])
  @@index([component])
  @@index([timestamp])
  @@map("performance_metrics")
}

// Admin audit log for dataset management
model AdminAuditLog {
  id String @id @default(cuid())

  // Admin action details
  adminUserId String // Admin user identifier
  action      String // "relabel", "delete", "export", "bulk_operation"
  targetType  String // "drawing_attempt", "character_profile", "dataset"
  targetId    String? // ID of affected record

  // Action details
  oldValue      Json? // Previous value (for updates)
  newValue      Json? // New value (for updates)
  justification String? // Reason for the action

  // Metadata
  ipAddress String? // Admin IP address
  userAgent String? // Admin browser/client
  timestamp DateTime @default(now())

  @@index([adminUserId])
  @@index([action])
  @@index([timestamp])
  @@map("admin_audit_logs")
}
