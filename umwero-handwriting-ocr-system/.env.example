# =============================================================================
# umwero-handwriting-ocr-system — Environment Variables
# =============================================================================
# Used by docker-compose.yml and the backend Python service.
# Copy to .env for local development:
#   cp .env.example .env
# =============================================================================

# PostgreSQL (used by docker-compose postgres service)
POSTGRES_PASSWORD=umwero_secure_password_change_me

# Redis (used by docker-compose redis service)
REDIS_PASSWORD=redis_secure_password_change_me

# Backend service
DATABASE_URL=postgresql://umwero_user:umwero_secure_password_change_me@postgres:5432/umwero_ocr
REDIS_URL=redis://:redis_secure_password_change_me@redis:6379/0

# Font path inside the container
UMWERO_FONT_PATH=/app/fonts/umwero.ttf

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Cache TTLs (seconds)
CACHE_DEFAULT_TTL=3600
CACHE_REFERENCE_TTL=86400
CACHE_FEATURE_TTL=43200
